<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ SplashScreen API theme for SDK 31+ (dark mode) -->
    <!-- Shows navy+gold splash immediately while app loads -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/navy_launch</item>
        <item name="android:windowSplashScreenBackground">@color/navy_launch</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/navy_launch</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>